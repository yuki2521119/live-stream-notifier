{
  "manifest_version": 3,
  "name": "StreamLauncher",
  "version": "1.0.0",
  "description": "YouTubeチャンネルのライブ配信開始を検知し、自動でブラウザタブを開きます",
  "permissions": ["notifications", "tabs", "storage", "alarms"],
  "host_permissions": ["https://www.youtube.com/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com;"
  },
  "background": { "service_worker": "background.js", "type": "module" },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
